# JWT Configuration
# 生成强密钥: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
NUXT_JWT_SECRET=your-super-secret-jwt-key-at-least-64-characters-long-change-this-in-production

# Geetest Captcha Configuration
NUXT_GEETEST_ID=your_geetest_id
NUXT_GEETEST_KEY=your_geetest_key

# Database
NUXT_DATABASE_URL=./data.db

# Rate Limiting
NUXT_RATE_LIMIT_MAX=100
NUXT_RATE_LIMIT_WINDOW_MS=900000

# Security
NUXT_SESSION_MAX_AGE=604800
